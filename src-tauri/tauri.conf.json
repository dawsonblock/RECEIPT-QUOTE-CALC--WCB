{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WCB Receipt Builder",
  "version": "0.1.0",
  "identifier": "com.dawsonblock.wcbreceiptbuilder",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../apps/web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WCB Receipt Builder",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 650
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "Productivity",
    "resources": ["../apps/server/dist"],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "entitlements": null
    }
  }
}
